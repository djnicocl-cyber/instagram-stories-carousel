{
  "manifest_version": 3,
  "name": "Instagram Stories Carousel",
  "version": "1.0",
  "description": "Reproduce historias de Instagram en bucle para eventos",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": ["https://www.instagram.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Stories Carousel"
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/stories/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
